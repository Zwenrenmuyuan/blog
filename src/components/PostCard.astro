---
import { getPostPath, type Post } from '../lib/posts';
import { siteConfig } from '../site.config';
import TagList from './TagList.astro';

interface Props {
  post: Post;
  headingLevel?: 2 | 3;
  variant?: 'default' | 'featured';
  linkTags?: boolean;
}

const {
  post,
  headingLevel = 2,
  variant = 'default',
  linkTags = false,
} = Astro.props;
const postPath = getPostPath(post);
const dateFormatter = new Intl.DateTimeFormat(siteConfig.locale, {
  dateStyle: 'long',
  timeZone: siteConfig.timezone,
});
---

<article class:list={['post-card', `post-card--${variant}`]} data-post-card>
	<div class="post-card__meta">
		{variant === 'featured' && <span>精选</span>}
		<time datetime={post.data.publishedAt.toISOString()}>
			{dateFormatter.format(post.data.publishedAt)}
		</time>
	</div>
	{headingLevel === 3 ? (
		<h3><a href={postPath}>{post.data.title}</a></h3>
	) : (
		<h2><a href={postPath}>{post.data.title}</a></h2>
	)}
	<p class="post-card__description">{post.data.description}</p>
	<TagList tagIds={post.data.tags} linked={linkTags} />
</article>

<style>
	.post-card {
		padding-block: var(--space-5);
		border-block: 1px solid var(--color-border);
	}

	.post-card--featured {
		padding-inline: var(--space-5);
		border: 1px solid var(--color-border);
		border-inline-start: 4px solid var(--color-accent);
		border-radius: var(--radius-medium);
	}

	.post-card__meta {
		display: flex;
		margin-block-end: var(--space-2);
		align-items: center;
		gap: var(--space-3);
		color: var(--color-muted);
		font-size: 0.8125rem;
	}

	.post-card__meta span {
		color: var(--color-accent);
		font-weight: 700;
		letter-spacing: 0.08em;
	}

	.post-card h2,
	.post-card h3 {
		margin: 0;
		font-family: var(--font-serif);
		font-size: clamp(1.35rem, 3vw, 2rem);
		line-height: 1.25;
	}

	.post-card h2 a,
	.post-card h3 a {
		color: var(--color-text);
		text-decoration-color: var(--color-accent);
		text-decoration-thickness: 0.08em;
		text-underline-offset: 0.2em;
	}

	.post-card h2 a:hover,
	.post-card h3 a:hover {
		color: var(--color-accent);
	}

	.post-card__description {
		max-width: 42rem;
		margin-block: var(--space-3) var(--space-4);
		color: var(--color-muted);
	}

	@media (max-width: 30rem) {
		.post-card--featured {
			padding-inline: var(--space-4);
		}
	}
</style>
