---
interface Props {
  year: string;
}

const { year } = Astro.props;
---

<footer class="site-footer">
	<div class="site-footer__inner">
		<p><span aria-hidden="true">©</span> {year} 旁注</p>
		<a href="/rss.xml">RSS</a>
		<slot />
	</div>
</footer>

<style>
	.site-footer {
		border-block-start: 1px solid var(--color-border);
		color: var(--color-muted);
	}

	.site-footer__inner {
		display: flex;
		width: min(calc(100% - (2 * var(--page-gutter))), var(--content-max));
		min-height: 5rem;
		margin-inline: auto;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-4);
		font-size: 0.875rem;
	}

	.site-footer p {
		margin: 0;
	}

	.site-footer a {
		font-weight: 700;
	}
</style>
