---
interface Props {
  label: string;
  href?: string;
}

const { label, href } = Astro.props;
---

{href ? (
	<a class="tag-pill" href={href}>{label}</a>
) : (
	<span class="tag-pill">{label}</span>
)}

<style>
	.tag-pill {
		display: inline-flex;
		min-height: 1.75rem;
		padding: 0.12rem var(--space-3);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-pill);
		align-items: center;
		color: var(--color-muted);
		font-size: 0.8125rem;
		line-height: 1.25;
		text-decoration: none;
	}

	a.tag-pill:hover {
		border-color: var(--color-accent);
		color: var(--color-accent);
	}
</style>
