---
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { primaryNavigation } from '../data/navigation';
import {
  createStructuredData,
  getAbsoluteSeoImage,
  resolveSeoImage,
  serializeJsonLd,
  type ArticleSeoData,
  type PageKind,
  type SeoImage,
} from '../lib/seo';
import { getAbsoluteSiteUrl, siteConfig } from '../site.config';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  mainClass?: string;
  pageKind?: PageKind;
  canonicalPath?: `/${string}` | false;
  image?: SeoImage;
  article?: ArticleSeoData;
}

const {
  title,
  description,
  mainClass,
  pageKind = 'collection',
  canonicalPath,
  image,
  article,
} = Astro.props;
const currentYear = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  timeZone: siteConfig.timezone,
}).format(new Date());
const isDraft = article?.draft ?? false;
const hasCanonical = canonicalPath !== false && pageKind !== 'not-found' && !isDraft;
const resolvedCanonicalPath = canonicalPath === false
  ? undefined
  : (canonicalPath ?? Astro.url.pathname) as `/${string}`;
const canonicalUrl = hasCanonical && resolvedCanonicalPath
  ? getAbsoluteSiteUrl(resolvedCanonicalPath)
  : undefined;
const robots = isDraft
  ? 'noindex, nofollow'
  : pageKind === 'search' || pageKind === 'not-found'
    ? 'noindex, follow'
    : undefined;
const shouldRenderSharingMetadata = pageKind !== 'not-found' && !isDraft;
const sharingImage = getAbsoluteSeoImage(resolveSeoImage(image));
const structuredData = createStructuredData({
  pageKind,
  canonicalUrl,
  title,
  description,
  image,
  article,
});
const isPublishedArticle = pageKind === 'article' && article !== undefined && !isDraft;
---

<!doctype html>
<html lang={siteConfig.locale} data-theme="system">
	<head>
		<meta charset="utf-8" />
		<script is:inline>
			(() => {
				const root = document.documentElement;
				const storageKey = 'pangzhu-theme';
				const preferences = ['system', 'light', 'dark'];

				root.classList.add('js');

				try {
					const storedPreference = window.localStorage.getItem(storageKey);

					if (storedPreference && preferences.includes(storedPreference)) {
						root.dataset.theme = storedPreference;
					} else {
						root.dataset.theme = 'system';

						if (storedPreference !== null) {
							window.localStorage.removeItem(storageKey);
						}
					}
				} catch {
					root.dataset.theme = 'system';
				}
			})();
		</script>
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta
			name="description"
			content={description}
			data-pagefind-meta={isPublishedArticle ? 'description[content]' : undefined}
		/>
		{robots && <meta name="robots" content={robots} />}
		{canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
		{pageKind !== 'not-found' && (
			<link
				rel="alternate"
				type="application/rss+xml"
				title={`${siteConfig.title} RSS`}
				href={getAbsoluteSiteUrl('/rss.xml')}
			/>
		)}
		{isPublishedArticle && article && (
			<>
				<meta
					name="pagefind:publishedAt"
					content={article.publishedAt.toISOString()}
					data-pagefind-meta="publishedAt[content]"
				/>
				<meta
					name="pagefind:tags"
					content={JSON.stringify(article.tags)}
					data-pagefind-meta="tags[content]"
				/>
			</>
		)}
		{shouldRenderSharingMetadata && canonicalUrl && (
			<>
				<meta property="og:site_name" content={siteConfig.title} />
				<meta property="og:title" content={title} />
				<meta property="og:description" content={description} />
				<meta property="og:url" content={canonicalUrl} />
				<meta property="og:locale" content="zh_CN" />
				<meta property="og:type" content={pageKind === 'article' ? 'article' : 'website'} />
				<meta property="og:image" content={sharingImage.src} />
				<meta property="og:image:width" content={String(sharingImage.width)} />
				<meta property="og:image:height" content={String(sharingImage.height)} />
				<meta property="og:image:alt" content={sharingImage.alt} />
				<meta name="twitter:card" content="summary_large_image" />
				<meta name="twitter:title" content={title} />
				<meta name="twitter:description" content={description} />
				<meta name="twitter:image" content={sharingImage.src} />
				<meta name="twitter:image:alt" content={sharingImage.alt} />
			</>
		)}
		{isPublishedArticle && article && (
			<>
				<meta property="article:published_time" content={article.publishedAt.toISOString()} />
				<meta
					property="article:modified_time"
					content={(article.updatedAt ?? article.publishedAt).toISOString()}
				/>
				{article.tags.map((tag) => <meta property="article:tag" content={tag} />)}
			</>
		)}
		{structuredData.map((entry) => (
			<script is:inline type="application/ld+json" set:html={serializeJsonLd(entry)} />
		))}
		<title>{title}</title>
	</head>
	<body>
		<a class="skip-link" href="#main-content">跳到正文</a>
		<SiteHeader currentPath={Astro.url.pathname} items={primaryNavigation} />
		<main id="main-content" class:list={['site-main', mainClass]} tabindex="-1">
			<slot />
		</main>
		<SiteFooter year={currentYear} />
	</body>
</html>
