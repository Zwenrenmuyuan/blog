---
import { Image } from 'astro:assets';
import { render } from 'astro:content';

import AccessibleArticleInput from '../../components/AccessibleArticleInput.astro';
import ArticleEnhancements from '../../components/ArticleEnhancements.astro';
import ArticleToc from '../../components/ArticleToc.astro';
import PostNavigation from '../../components/PostNavigation.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import TagList from '../../components/TagList.astro';
import { getTag } from '../../data/tags';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatLongDate } from '../../lib/date';
import { getPostPath, getPosts, type Post } from '../../lib/posts';
import {
  buildTableOfContents,
  calculateReadingMinutes,
  getPostNeighbors,
  selectRelatedPosts,
  type PostNeighbors,
} from '../../lib/reading';
import { siteConfig } from '../../site.config';

interface Props {
  post: Post;
  neighbors: PostNeighbors<Post>;
  relatedPosts: Post[];
}

export async function getStaticPaths() {
  const posts = await getPosts();

  return posts.map((post) => {
    const neighbors = getPostNeighbors(posts, post.id);
    const relatedPosts = selectRelatedPosts(posts, post, {
      limit: 3,
      excludeIds: [neighbors.previous?.id, neighbors.next?.id].filter(
        (id): id is string => id !== undefined,
      ),
    });

    return {
      params: { slug: post.id },
      props: { post, neighbors, relatedPosts },
    };
  });
}

const { post, neighbors, relatedPosts } = Astro.props;
const { Content, headings } = await render(post);
const tocHeadings = headings.filter(
  (heading) => (heading.depth === 2 || heading.depth === 3) && heading.slug !== 'footnote-label',
);
const hasTableOfContents = tocHeadings.length >= 2;
const tableOfContents = hasTableOfContents ? buildTableOfContents(tocHeadings) : [];
const readingMinutes = calculateReadingMinutes(post.body ?? '');
const tagLabels = post.data.tags.map((tagId) => getTag(tagId).label);
const seoImage = post.data.cover && post.data.coverAlt
  ? {
      src: post.data.cover.src,
      alt: post.data.coverAlt,
      width: post.data.cover.width,
      height: post.data.cover.height,
    }
  : undefined;
---

<BaseLayout
	title={`${post.data.title}｜${siteConfig.title}`}
	description={post.data.description}
	pageKind="article"
	canonicalPath={post.data.draft ? false : getPostPath(post) as `/posts/${string}/`}
	image={seoImage}
	article={{
		headline: post.data.title,
		publishedAt: post.data.publishedAt,
		updatedAt: post.data.updatedAt,
		tags: tagLabels,
		draft: post.data.draft,
	}}
>
	<article class="post" data-article>
		<div
			class:list={['post__header-layout', { 'post__header-layout--with-toc': hasTableOfContents }]}
		>
			<header class="post__header">
				{post.data.draft && <p class="post__draft" role="status">草稿预览</p>}
				<p class="post__eyebrow">旁注 · 文章</p>
				<h1
					data-pagefind-body={post.data.draft ? undefined : true}
					data-pagefind-meta={post.data.draft ? undefined : 'title'}
				>
					{post.data.title}
				</h1>
				<p
					class="post__description"
					data-pagefind-body={post.data.draft ? undefined : true}
				>
					{post.data.description}
				</p>
				<div class="post__meta">
					<p>
						<span>发布于 </span>
						<time datetime={post.data.publishedAt.toISOString()}>
							{formatLongDate(post.data.publishedAt)}
						</time>
					</p>
					{post.data.updatedAt && (
						<p>
							<span>更新于 </span>
							<time datetime={post.data.updatedAt.toISOString()}>
								{formatLongDate(post.data.updatedAt)}
							</time>
						</p>
					)}
					<p data-reading-time>约 {readingMinutes} 分钟阅读</p>
					<TagList tagIds={post.data.tags} linked searchable={!post.data.draft} />
				</div>
			</header>
		</div>
		{post.data.cover && post.data.coverAlt && (
			<figure
				class:list={['post__cover', { 'post__cover--with-toc': hasTableOfContents }]}
				data-post-cover
			>
				<Image
					src={post.data.cover}
					alt={post.data.coverAlt}
					loading="eager"
					decoding="async"
					fetchpriority="high"
					sizes="(max-width: 45rem) 100vw, 45rem"
				/>
			</figure>
		)}
		<div
			class:list={['post__reading', { 'post__reading--with-toc': hasTableOfContents }]}
		>
			{hasTableOfContents && <ArticleToc items={tableOfContents} />}
			<div class="post__content">
				<div
					class="prose"
					data-article-body
					data-pagefind-body={post.data.draft ? undefined : true}
				>
					<Content components={{ input: AccessibleArticleInput }} />
				</div>
				<ArticleEnhancements />
			</div>
		</div>
		<footer class="post__footer">
			<PostNavigation neighbors={neighbors} />
			<RelatedPosts posts={relatedPosts} />
			<p class="post__back-link"><a href="/posts/">返回全部文章</a></p>
		</footer>
	</article>
</BaseLayout>

<style>
	.post {
		width: 100%;
	}

	.post__header-layout {
		width: min(100%, var(--reading-max));
		margin-inline: auto;
	}

	.post__header {
		display: grid;
		padding-block-end: var(--space-7);
		border-block-end: 1px solid var(--color-border);
		gap: var(--space-4);
	}

	.post__eyebrow,
	.post__draft {
		margin: 0;
		color: var(--color-accent);
		font-size: 0.8125rem;
		font-weight: 700;
		letter-spacing: 0.12em;
	}

	.post__draft {
		width: fit-content;
		padding: var(--space-1) var(--space-3);
		border: 1px solid var(--color-accent);
		border-radius: var(--radius-pill);
		letter-spacing: 0.06em;
	}

	.post h1 {
		margin: 0;
		font-family: var(--font-serif);
		font-size: clamp(2rem, 5vw, 3.75rem);
		line-height: 1.18;
	}

	.post__description {
		max-width: 40rem;
		margin: 0;
		color: var(--color-muted);
		font-size: clamp(1.05rem, 2vw, 1.2rem);
	}

	.post__meta {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: var(--space-4);
	}

	.post__meta p {
		margin: 0;
		color: var(--color-muted);
		font-size: 0.875rem;
		white-space: nowrap;
	}

	.post__cover {
		width: min(100%, var(--reading-max));
		margin: var(--space-7) auto 0;
	}

	.post__cover :global(img) {
		display: block;
		width: 100%;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-medium);
	}

	.post__reading {
		width: min(100%, var(--reading-max));
		margin: var(--space-7) auto 0;
	}

	.post__content {
		min-width: 0;
	}

	.post__footer {
		display: grid;
		width: min(100%, 64rem);
		margin-inline: auto;
		margin-block-start: var(--space-7);
		padding-block-start: var(--space-5);
		border-block-start: 1px solid var(--color-border);
		gap: var(--space-7);
	}

	.post__back-link {
		margin: 0;
	}

	@media (min-width: 64rem) {
		.post__header-layout--with-toc,
		.post__cover--with-toc,
		.post__reading--with-toc {
			display: grid;
			width: min(100%, 64rem);
			grid-template-columns: minmax(0, var(--reading-max)) minmax(14rem, 16rem);
			column-gap: var(--space-7);
		}

		.post__header-layout--with-toc > .post__header,
		.post__cover--with-toc > :global(img) {
			grid-column: 1;
		}

		.post__reading--with-toc > :global(.article-toc--desktop) {
			grid-column: 2;
			grid-row: 1;
		}

		.post__reading--with-toc > .post__content {
			grid-column: 1;
			grid-row: 1;
		}
	}

	@media (max-width: 36rem) {
		.post__meta {
			align-items: start;
			flex-direction: column;
		}
	}
</style>
