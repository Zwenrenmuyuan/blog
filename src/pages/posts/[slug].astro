---
import { render, type CollectionEntry } from 'astro:content';

import TagList from '../../components/TagList.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatLongDate } from '../../lib/date';
import { getPosts } from '../../lib/posts';
import { siteConfig } from '../../site.config';

interface Props {
  post: CollectionEntry<'posts'>;
}

export async function getStaticPaths() {
  const posts = await getPosts();

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout
	title={`${post.data.title} | ${siteConfig.title}`}
	description={post.data.description}
>
	<article class="post">
		<header class="post__header">
			{post.data.draft && <p class="post__draft" role="status">草稿预览</p>}
			<p class="post__eyebrow">旁注 · 文章</p>
			<h1>{post.data.title}</h1>
			<p class="post__description">{post.data.description}</p>
			<div class="post__meta">
				<p>
					<span class="visually-hidden">发布于</span>
					<time datetime={post.data.publishedAt.toISOString()}>
						{formatLongDate(post.data.publishedAt)}
					</time>
				</p>
				{post.data.updatedAt && (
					<p>
						<span>更新于 </span>
						<time datetime={post.data.updatedAt.toISOString()}>
							{formatLongDate(post.data.updatedAt)}
						</time>
					</p>
				)}
				<TagList tagIds={post.data.tags} linked />
			</div>
		</header>
		<div class="prose">
			<Content />
		</div>
		<footer class="post__footer">
			<a href="/posts/">返回全部文章</a>
		</footer>
	</article>
</BaseLayout>

<style>
	.post {
		width: min(100%, var(--reading-max));
		margin-inline: auto;
	}

	.post__header {
		display: grid;
		padding-block-end: var(--space-7);
		border-block-end: 1px solid var(--color-border);
		gap: var(--space-4);
	}

	.post__eyebrow,
	.post__draft {
		margin: 0;
		color: var(--color-accent);
		font-size: 0.8125rem;
		font-weight: 700;
		letter-spacing: 0.12em;
	}

	.post__draft {
		width: fit-content;
		padding: var(--space-1) var(--space-3);
		border: 1px solid var(--color-accent);
		border-radius: var(--radius-pill);
		letter-spacing: 0.06em;
	}

	.post h1 {
		margin: 0;
		font-family: var(--font-serif);
		font-size: clamp(2rem, 5vw, 3.75rem);
		line-height: 1.18;
	}

	.post__description {
		max-width: 40rem;
		margin: 0;
		color: var(--color-muted);
		font-size: clamp(1.05rem, 2vw, 1.2rem);
	}

	.post__meta {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-4);
	}

	.post__meta p {
		margin: 0;
		color: var(--color-muted);
		font-size: 0.875rem;
		white-space: nowrap;
	}

	.post > .prose {
		margin-block-start: var(--space-7);
	}

	.post__footer {
		margin-block-start: var(--space-7);
		padding-block-start: var(--space-5);
		border-block-start: 1px solid var(--color-border);
	}

	@media (max-width: 36rem) {
		.post__meta {
			align-items: start;
			flex-direction: column;
		}
	}
</style>
