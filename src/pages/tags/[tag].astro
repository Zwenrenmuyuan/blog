---
import type { GetStaticPaths } from 'astro';

import PageHeader from '../../components/PageHeader.astro';
import PostList from '../../components/PostList.astro';
import { tagEntries, type TagEntry, type TagId } from '../../data/tags';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { countPostsByTag, filterPostsByTag, type TagCount } from '../../lib/post-data';
import { getPublishedPosts, type Post } from '../../lib/posts';
import { siteConfig } from '../../site.config';

interface Props {
  tag: TagEntry;
  tagCount: TagCount<TagId>;
  posts: Post[];
}

export const getStaticPaths: GetStaticPaths = async () => {
  const posts = await getPublishedPosts();
  const tagCounts = countPostsByTag(posts, tagEntries);

  return tagEntries.map((tag) => ({
    params: { tag: tag.id },
    props: {
      tag,
      tagCount: tagCounts.find((entry) => entry.id === tag.id),
      posts: filterPostsByTag(posts, tag.id),
    },
  }));
};

const { tag, tagCount, posts } = Astro.props;
---

<BaseLayout
	title={`${tag.label}｜标签｜${siteConfig.title}`}
	description={`${tag.description}，共 ${tagCount.count} 篇文章。`}
	pageKind="collection"
>
	<PageHeader
		eyebrow="标签"
		title={tag.label}
		description={`${tag.description}，共 ${tagCount.count} 篇文章。`}
	/>
	<section class="tag-posts" aria-label={`${tag.label}标签下的文章`}>
		<PostList
			posts={posts}
			emptyTitle="这个标签下还没有文章"
			emptyDescription="文章发布并使用这个标签后，会出现在这里。"
			emptyActionHref="/tags/"
			emptyActionLabel="返回全部标签"
		/>
	</section>
	<p class="back-link"><a href="/tags/">查看全部标签</a></p>
</BaseLayout>

<style>
	.tag-posts {
		margin-block-start: var(--space-6);
	}

	.back-link {
		margin-block: var(--space-6) 0;
	}
</style>
